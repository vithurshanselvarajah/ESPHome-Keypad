# ====================================================
#  secrets.yaml.example
#
#  Copy this file to secrets.yaml and fill in your values.
#  secrets.yaml is gitignored and must never be committed.
#
#  Generate api_encryption_key and ota_password with:
#    openssl rand -base64 32
# ====================================================

wifi_ssid: "YourNetworkName"
wifi_password: "YourWiFiPassword"

# 32-byte base64 key — must match the key you enter in Home Assistant
api_encryption_key: "REPLACE_WITH_openssl_rand_-base64_32_output="

# OTA update password
ota_password: "REPLACE_WITH_openssl_rand_-base64_32_output="
